# Frontend API and Socket endpoints
VITE_API_URL=https://your-backend.com/api
VITE_SOCKET_URL=https://your-backend.com

# WebRTC STUN servers
VITE_STUN_URLS=stun:stun1.l.google.com:19302,stun:stun2.l.google.com:19302

# Metered TURN credentials for WebRTC relay (required for cross-network video)
# Signup at https://www.metered.ca/ and get your credentials
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=

# Optional: force TURN-only routing (more secure but slower for local networks)
# Set to 'relay' to use only TURN, or 'all' to prefer direct then fallback to TURN
VITE_ICE_TRANSPORT_POLICY=all
