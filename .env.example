# Frontend API and Socket endpoints
# Example (Render backend): https://yourtherapist-api.onrender.com/api
VITE_API_URL=https://your-api-domain/api
# Optional; if omitted, app derives socket URL from VITE_API_URL
VITE_SOCKET_URL=https://your-api-domain

# WebRTC STUN/TURN
# Keep STUN list comma-separated.
VITE_STUN_URLS=stun:stun1.l.google.com:19302,stun:stun2.l.google.com:19302

# TURN is required for reliable video between different networks/mobile carriers.
# Example TURN URLs (comma-separated):
# VITE_TURN_URLS=turn:global.relay.metered.ca:80,turn:global.relay.metered.ca:443?transport=tcp
VITE_TURN_URLS=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=

# Optional: set relay to force TURN-only media routing.
# Allowed values: all | relay
VITE_ICE_TRANSPORT_POLICY=all
